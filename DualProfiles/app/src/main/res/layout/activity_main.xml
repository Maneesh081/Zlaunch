<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/bg_deep">

    <!-- Wallpaper layer -->
    <ImageView android:id="@+id/imageWallpaper" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:visibility="gone" />
    <View android:id="@+id/wallpaperOverlay" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#99000000" android:visibility="gone" />

    <!-- Floating Clock (DRAGGABLE) -->
    <LinearLayout android:id="@+id/clockArea" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:elevation="2dp" android:padding="16dp">
        <TextView android:id="@+id/textTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00" android:textColor="@color/text_primary" android:textSize="72sp" android:textStyle="bold" android:fontFamily="sans-serif-thin" android:letterSpacing="-0.02" android:gravity="center" />
        <TextView android:id="@+id/textDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Friday" android:textColor="@color/text_secondary" android:textSize="16sp" android:fontFamily="sans-serif-light" android:layout_marginTop="4dp" android:gravity="center" />
    </LinearLayout>

    <!-- Floating Quote (DRAGGABLE) -->
    <LinearLayout android:id="@+id/quoteArea" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:elevation="2dp" android:padding="12dp">
        <TextView android:id="@+id/textQuote" android:layout_width="280dp" android:layout_height="wrap_content" android:textColor="@color/text_muted" android:textSize="15sp" android:fontFamily="sans-serif-light" android:lineSpacingExtra="6dp" android:gravity="center" android:fontStyle="italic" />
    </LinearLayout>

    <!-- Settings + Focus buttons (fixed bottom) -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_gravity="bottom|center_horizontal" android:layout_marginBottom="32dp" android:elevation="2dp">
        <ImageButton android:id="@+id/btnFocus" android:layout_width="44dp" android:layout_height="44dp" android:background="?android:attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_recent_history" android:alpha="0.5" android:scaleType="center" />
        <View android:layout_width="24dp" android:layout_height="1dp" />
        <ImageButton android:id="@+id/btnSettings" android:layout_width="44dp" android:layout_height="44dp" android:background="?android:attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_preferences" android:alpha="0.5" android:scaleType="center" />
    </LinearLayout>

    <!-- Floating Widget (DRAGGABLE) -->
    <FrameLayout android:id="@+id/widgetArea" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" android:elevation="4dp" />

    <!-- Floating App List (DRAGGABLE) -->
    <LinearLayout android:id="@+id/floatingAppList" android:layout_width="240dp" android:layout_height="wrap_content" android:orientation="vertical" android:elevation="4dp" android:background="#33000000">
        <LinearLayout android:id="@+id/dragHandle" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp" android:paddingTop="12dp" android:paddingBottom="12dp" android:background="#00000000">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Apps" android:textColor="@color/text_muted" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.1" />
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerApps" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxHeight="400dp" android:clipToPadding="false" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingBottom="8dp" />
    </LinearLayout>

    <!-- Focus Mode Overlay -->
    <LinearLayout android:id="@+id/focusOverlay" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:background="@color/bg_deep" android:visibility="gone" android:elevation="8dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/focus_mode_on" android:textColor="@color/accent_green" android:textSize="14sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.2" />
        <TextView android:id="@+id/textFocusTimer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00:00" android:textColor="@color/text_muted" android:textSize="18sp" android:fontFamily="sans-serif-thin" android:layout_marginTop="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="time focused" android:textColor="@color/text_muted" android:textSize="11sp" android:alpha="0.5" android:layout_marginTop="4dp" />
        <Button android:id="@+id/btnExitFocus" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Exit Focus Mode" android:textColor="@color/accent_green" android:textSize="14sp" android:textAllCaps="false" android:layout_marginTop="40dp" />
    </LinearLayout>

</FrameLayout>